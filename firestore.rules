rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    match /nodes/{nodeId} {
      // Allow read and delete for any authenticated user (Google or Anonymous)
      // Allow create/update is restricted to the backend (Firebase Admin SDK)
      allow read, delete: if request.auth != null;
      allow create, update: if false;
    }
  }
}
